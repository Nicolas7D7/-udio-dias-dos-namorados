<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Uma carta em áudio em formato de mini álbum para o Dia dos Namorados."
    />
    <!-- Troque o título da aba do navegador aqui, se quiser. -->
    <title>Dia dos Namorados | Nicolas para Phamyla</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <section class="intro-screen" id="introScreen" aria-labelledby="introTitle">
      <div class="intro-background" aria-hidden="true"></div>

      <div class="intro-content">
        <p class="intro-kicker">Uma surpresa para ouvir com calma</p>
        <h1 id="introTitle">Antes de ouvir...</h1>
        <p>Encontra um lugar tranquilo. Essa mensagem é só nossa.</p>
        <button class="primary-action" id="startButton" type="button">
          Estou pronta para ouvir
        </button>
      </div>
    </section>

    <main class="album-screen" id="albumScreen" aria-hidden="true">
      <section class="album-shell" aria-label="Mini álbum de Dia dos Namorados">
        <div class="album-cover" aria-label="Capa romântica do álbum">
          <div class="cover-frame">
            <span class="cover-star star-one" aria-hidden="true"></span>
            <span class="cover-star star-two" aria-hidden="true"></span>
            <span class="cover-star star-three" aria-hidden="true"></span>
            <span class="cover-ring ring-one" aria-hidden="true"></span>
            <span class="cover-ring ring-two" aria-hidden="true"></span>
            <span class="cover-heart heart-left" aria-hidden="true"></span>
            <span class="cover-heart heart-right" aria-hidden="true"></span>
            <div class="cover-initials" aria-hidden="true">N + P</div>
            <p aria-hidden="true">12.06</p>
          </div>
        </div>

        <div class="album-info">
          <!-- Os textos do álbum também podem ser trocados no arquivo script.js. -->
          <p class="album-label">Mini álbum particular</p>
          <h2 id="albumTitle">Dia dos Namorados</h2>
          <p class="album-artist" id="albumArtist">Nicolas para Phamyla</p>
          <p class="album-subtitle" id="albumSubtitle">
            Uma carta que eu preferi te entregar com a minha voz.
          </p>

          <div class="now-playing" aria-live="polite">
            <span>Tocando agora</span>
            <strong id="currentTrackTitle">Antes de tudo</strong>
          </div>

          <ol class="track-list" id="trackList" aria-label="Lista de faixas"></ol>

          <div class="player-panel" aria-label="Player de áudio">
            <audio id="audioPlayer" preload="metadata"></audio>

            <div class="progress-area">
              <input
                id="progressBar"
                class="progress-bar"
                type="range"
                min="0"
                max="100"
                value="0"
                step="0.1"
                aria-label="Progresso da faixa"
              />
              <div class="time-row">
                <span id="currentTime">0:00</span>
                <span id="durationTime">0:00</span>
              </div>
            </div>

            <div class="controls">
              <button
                class="control-button side-control"
                id="prevButton"
                type="button"
                aria-label="Faixa anterior"
                title="Faixa anterior"
              >
                <span aria-hidden="true">&larr;</span>
                <span aria-hidden="true" class="heart-icon"></span>
              </button>

              <button
                class="control-button play-control"
                id="playButton"
                type="button"
                aria-label="Tocar"
                title="Tocar ou pausar"
              >
                <span id="playIcon" class="play-symbol is-play" aria-hidden="true"></span>
              </button>

              <button
                class="control-button side-control"
                id="nextButton"
                type="button"
                aria-label="Próxima faixa"
                title="Próxima faixa"
              >
                <span aria-hidden="true" class="heart-icon"></span>
                <span aria-hidden="true">&rarr;</span>
              </button>
            </div>

            <p class="player-message" id="playerMessage" aria-live="polite"></p>
          </div>
        </div>
      </section>
    </main>

    <script src="script.js"></script>
  </body>
</html>
